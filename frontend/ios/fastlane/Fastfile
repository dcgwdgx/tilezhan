default_platform(:ios)

platform :ios do
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"],
    )

    sigh(
      app_identifier: "com.tilezhan.app",
      username: "dcgwdgx@126.com",
      team_id: "74797U8R45",
      api_key: api_key,
    )

    # Use GitHub run number as build number (always unique, always increasing)
    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i,
      xcodeproj: "Runner.xcodeproj",
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      configuration: "Release",
      xcargs: "DEVELOPMENT_TEAM=74797U8R45 CODE_SIGN_STYLE=Manual",
      export_options: {
        provisioningProfiles: { "com.tilezhan.app": "TileZhan App Store" }
      },
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
